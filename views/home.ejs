<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>URL Shortener</title>
    <link rel="stylesheet" href="/home.css">
</head>

<body>
    <div class="container">
        <h1>🔗 URL Shortener</h1>

        <!-- Generate -->
        <div class="card">
            <form method="POST" action="/url">
                <label>Enter valid URL to shorten</label>
                <input type="text" name="url" placeholder="https://example.com" required>
                <button type="submit">Generate</button>
            </form>

            <% if (locals.id) { %>
                <div class="success">
                    Short URL ID: <strong>
                        <%= id %>
                    </strong>
                </div>
                <% } %>

                    <% if (locals.idExists) { %>
                        <div class="warning">
                            Short ID already exists: <strong>
                                <%= shortId %>
                            </strong>
                        </div>
                        <% } %>
        </div>

        <!-- Redirect -->
        <div class="card">
            <form method="GET" action="/url">
                <label>Enter short ID to redirect</label>
                <input type="text" name="shortId" placeholder="abc123" required>
                <button type="submit">Redirect</button>
            </form>
        </div>

        <!-- Delete -->
        <div class="card">
            <form method="POST" action="/url/delete">
                <label>Enter URL to delete</label>
                <input type="text" name="redirectUrl" placeholder="https://example.com" required>
                <button type="submit">Delete</button>
            </form>

            <% if (locals.deletedUrl) { %>
                <div class="warning">
                    Deleted URL: <strong>
                        <%= deletedUrl.redirectUrl %>
                    </strong>
                </div>
                <% } %>
        </div>

        <% if (locals.urls && urls.length> 0) { %>
            <div class="card">
                <h3>Stored URLs</h3>
                <table>
                    <thead>
                        <tr>
                            <th>Short ID</th>
                            <th>Original URL</th>
                            <th>Clicks</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% urls.forEach(url=> { %>
                            <tr>
                                <td>
                                    <%= url.shortId %>
                                </td>
                                <td>
                                    <%= url.redirectUrl %>
                                </td>
                                <td>
                                    <%= url.visitHistory.length %>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>
            </div>
            <% } %>
    </div>
</body>

</html>